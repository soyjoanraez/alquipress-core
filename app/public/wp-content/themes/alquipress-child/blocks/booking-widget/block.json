{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "alquipress-child/booking-widget",
  "title": "Formulario de reserva",
  "category": "alquipress",
  "icon": "calendar-alt",
  "description": "Calendario de reserva y formulario WC Bookings integrado para la ficha de propiedad.",
  "textdomain": "alquipress-child",
  "supports": { "html": false },
  "attributes": {
    "sticky": { "type": "boolean", "default": true },
    "showCleaningFee": { "type": "boolean", "default": true },
    "showLaundryFee": { "type": "boolean", "default": true }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php"
}
