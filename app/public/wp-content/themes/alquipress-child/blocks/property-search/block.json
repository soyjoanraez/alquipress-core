{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "alquipress-child/property-search",
  "title": "Buscador de propiedades",
  "category": "alquipress",
  "icon": "search",
  "description": "Formulario de búsqueda con fechas, huéspedes y ubicación. Envía a la página de resultados vía GET.",
  "textdomain": "alquipress-child",
  "supports": { "html": false, "align": ["wide", "full"] },
  "attributes": {
    "title": { "type": "string", "default": "Encuentra tu alojamiento" },
    "subtitle": { "type": "string", "default": "" },
    "resultsPage": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php"
}
