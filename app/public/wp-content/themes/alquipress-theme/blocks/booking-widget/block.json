{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "alquipress/booking-widget",
  "title": "Widget de Reserva",
  "category": "alquipress",
  "icon": "calendar-alt",
  "description": "Widget flotante para realizar reservas",
  "keywords": ["reserva", "booking", "widget", "formulario"],
  "textdomain": "alquipress-theme",
  "supports": {
    "html": false
  },
  "attributes": {
    "sticky": {
      "type": "boolean",
      "default": true
    },
    "showCleaningFee": {
      "type": "boolean",
      "default": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php"
}
