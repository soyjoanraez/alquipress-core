{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "alquipress/hero-search",
  "title": "Hero con Buscador",
  "category": "alquipress",
  "icon": "search",
  "description": "Bloque hero con buscador integrado de propiedades",
  "keywords": ["hero", "buscador", "búsqueda", "propiedades"],
  "textdomain": "alquipress-theme",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Encuentra tu Refugio en la Costa Blanca"
    },
    "subtitle": {
      "type": "string",
      "default": "Más de 200 propiedades disponibles para tu estancia perfecta"
    },
    "backgroundType": {
      "type": "string",
      "default": "image",
      "enum": ["image", "video"]
    },
    "backgroundImage": {
      "type": "object"
    },
    "backgroundVideo": {
      "type": "string"
    },
    "overlayOpacity": {
      "type": "number",
      "default": 0.4
    },
    "resultsPage": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php"
}
