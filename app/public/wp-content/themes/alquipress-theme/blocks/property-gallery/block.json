{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "alquipress/property-gallery",
  "title": "Galería de Propiedad",
  "category": "alquipress",
  "icon": "format-gallery",
  "description": "Galería premium con lightbox para propiedades",
  "keywords": ["galería", "imágenes", "lightbox"],
  "textdomain": "alquipress-theme",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "layout": {
      "type": "string",
      "default": "main-plus-grid",
      "enum": ["main-plus-grid", "carousel", "masonry"]
    },
    "showVideoTour": {
      "type": "boolean",
      "default": false
    },
    "videoTourUrl": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php"
}
